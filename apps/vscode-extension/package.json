{
  "name": "keep-vscode",
  "displayName": "Keep",
  "description": "Secure environment management from VS Code.",
  "version": "0.4.0",
  "publisher": "keep",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmedamsoliman-1/keep.git",
    "directory": "apps/vscode-extension"
  },
  "homepage": "https://github.com/ahmedamsoliman-1/keep#readme",
  "icon": "images/icon.png",
  "bugs": {
    "url": "https://github.com/ahmedamsoliman-1/keep/issues"
  },
  "keywords": [
    "dotenv",
    "environment",
    "secrets",
    "security",
    "aamsdn",
    "keep"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:keep.explorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "keep.signIn",
        "title": "Sign in",
        "category": "Keep"
      },
      {
        "command": "keep.signOut",
        "title": "Sign out",
        "category": "Keep"
      },
      {
        "command": "keep.status",
        "title": "Show connection status",
        "category": "Keep"
      },
      {
        "command": "keep.selectEnvironment",
        "title": "Select environment",
        "category": "Keep"
      },
      {
        "command": "keep.unlock",
        "title": "Unlock vault",
        "category": "Keep",
        "icon": "$(unlock)"
      },
      {
        "command": "keep.lock",
        "title": "Lock vault",
        "category": "Keep",
        "icon": "$(lock)"
      },
      {
        "command": "keep.pull",
        "title": "Pull environment → .env",
        "category": "Keep",
        "icon": "$(cloud-download)"
      },
      {
        "command": "keep.push",
        "title": "Push .env → environment",
        "category": "Keep",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "keep.clipboard.send",
        "title": "Send selection to Clipboard",
        "category": "Keep",
        "icon": "$(clippy)"
      },
      {
        "command": "keep.clipboard.history",
        "title": "Open Clipboard history",
        "category": "Keep",
        "icon": "$(history)"
      },
      {
        "command": "keep.clipboard.copyItem",
        "title": "Copy clipboard item",
        "category": "Keep",
        "icon": "$(copy)"
      },
      {
        "command": "keep.clipboard.insertItem",
        "title": "Insert clipboard item into editor",
        "category": "Keep",
        "icon": "$(insert)"
      },
      {
        "command": "keep.clipboard.pinItem",
        "title": "Pin clipboard item",
        "category": "Keep",
        "icon": "$(pin)"
      },
      {
        "command": "keep.clipboard.unpinItem",
        "title": "Unpin clipboard item",
        "category": "Keep",
        "icon": "$(pinned)"
      },
      {
        "command": "keep.clipboard.deleteItem",
        "title": "Delete clipboard item",
        "category": "Keep",
        "icon": "$(trash)"
      },
      {
        "command": "keep.passwords.unlock",
        "title": "Unlock vault to view passwords",
        "category": "Keep",
        "icon": "$(unlock)"
      },
      {
        "command": "keep.passwords.reveal",
        "title": "Reveal / hide password",
        "category": "Keep",
        "icon": "$(eye)"
      },
      {
        "command": "keep.passwords.copyPassword",
        "title": "Copy password",
        "category": "Keep",
        "icon": "$(copy)"
      },
      {
        "command": "keep.passwords.copyUsername",
        "title": "Copy username",
        "category": "Keep",
        "icon": "$(account)"
      },
      {
        "command": "keep.quickActions",
        "title": "Quick actions",
        "category": "Keep"
      },
      {
        "command": "keep.refresh",
        "title": "Refresh",
        "category": "Keep",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "keep",
          "title": "Keep",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "keep": [
        {
          "id": "keep.explorer",
          "name": "Environments"
        },
        {
          "id": "keep.clipboard",
          "name": "Clipboard"
        },
        {
          "id": "keep.passwords",
          "name": "Passwords"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "keep.explorer",
        "contents": "Connect this device to Keep to browse your projects and environments.\n[Sign in to Keep](command:keep.signIn)"
      },
      {
        "view": "keep.clipboard",
        "contents": "Sign in to Keep to see your cross-device clipboard stream.\n[Sign in to Keep](command:keep.signIn)"
      },
      {
        "view": "keep.passwords",
        "contents": "Sign in to Keep to view your managed passwords.\n[Sign in to Keep](command:keep.signIn)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "keep.refresh",
          "when": "view == keep.explorer",
          "group": "navigation@2"
        },
        {
          "command": "keep.clipboard.send",
          "when": "view == keep.clipboard",
          "group": "navigation@1"
        },
        {
          "command": "keep.clipboard.history",
          "when": "view == keep.clipboard",
          "group": "navigation@2"
        },
        {
          "command": "keep.refresh",
          "when": "view == keep.clipboard",
          "group": "navigation@3"
        },
        {
          "command": "keep.passwords.unlock",
          "when": "view == keep.passwords",
          "group": "navigation@1"
        },
        {
          "command": "keep.refresh",
          "when": "view == keep.passwords",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "command": "keep.clipboard.send",
          "when": "editorHasSelection",
          "group": "9_cutcopypaste@10"
        }
      ],
      "view/item/context": [
        {
          "command": "keep.pull",
          "when": "view == keep.explorer && viewItem == keepEnvironment",
          "group": "inline@1"
        },
        {
          "command": "keep.push",
          "when": "view == keep.explorer && viewItem == keepEnvironment",
          "group": "inline@2"
        },
        {
          "command": "keep.clipboard.insertItem",
          "when": "view == keep.clipboard && viewItem =~ /^keepClipboardItem/",
          "group": "inline@1"
        },
        {
          "command": "keep.clipboard.pinItem",
          "when": "view == keep.clipboard && viewItem == keepClipboardItem",
          "group": "inline@2"
        },
        {
          "command": "keep.clipboard.unpinItem",
          "when": "view == keep.clipboard && viewItem == keepClipboardItemPinned",
          "group": "inline@2"
        },
        {
          "command": "keep.clipboard.deleteItem",
          "when": "view == keep.clipboard && viewItem =~ /^keepClipboardItem/",
          "group": "inline@3"
        },
        {
          "command": "keep.clipboard.copyItem",
          "when": "view == keep.clipboard && viewItem =~ /^keepClipboardItem/",
          "group": "context@1"
        },
        {
          "command": "keep.passwords.reveal",
          "when": "view == keep.passwords && viewItem =~ /^keepPassword/",
          "group": "inline@1"
        },
        {
          "command": "keep.passwords.copyPassword",
          "when": "view == keep.passwords && viewItem =~ /^keepPassword/",
          "group": "inline@2"
        },
        {
          "command": "keep.passwords.copyUsername",
          "when": "view == keep.passwords && viewItem =~ /^keepPassword/",
          "group": "inline@3"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "keep.getStarted",
        "title": "Get started with Keep",
        "description": "Connect VS Code to your encrypted Keep environments.",
        "steps": [
          {
            "id": "signIn",
            "title": "Sign in",
            "description": "Approve this device in your browser — no password is typed into VS Code.\n[Sign in](command:keep.signIn)",
            "media": {
              "markdown": "walkthrough/sign-in.md"
            },
            "completionEvents": [
              "onCommand:keep.signIn"
            ]
          },
          {
            "id": "select",
            "title": "Select an environment",
            "description": "Bind a workspace folder to a project environment.\n[Select environment](command:keep.selectEnvironment)",
            "media": {
              "markdown": "walkthrough/select.md"
            },
            "completionEvents": [
              "onCommand:keep.selectEnvironment"
            ]
          },
          {
            "id": "pullPush",
            "title": "Pull and push",
            "description": "Fetch secrets into .env and publish local changes back.\n[Pull environment](command:keep.pull)",
            "media": {
              "markdown": "walkthrough/pull-push.md"
            },
            "completionEvents": [
              "onCommand:keep.pull"
            ]
          }
        ]
      }
    ],
    "configuration": {
      "title": "Keep",
      "properties": {
        "keep.serverUrl": {
          "type": "string",
          "default": "https://env.aamsdn.space",
          "description": "Keep server URL."
        },
        "keep.autoLockMinutes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1440,
          "description": "Minutes of inactivity before the vault locks in VS Code. Set to 0 to follow the vault's own auto-lock setting."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --minify --sourcemap --outfile=dist/extension.js",
    "package:vsix": "vsce package --pre-release --no-dependencies",
    "publish:pre": "vsce publish --pre-release --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "release": "./scripts/release.sh",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@keephq/api-client": "workspace:*",
    "@keephq/api-contract": "workspace:*",
    "@keephq/crypto": "workspace:*",
    "@keephq/dotenv": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1"
  }
}
